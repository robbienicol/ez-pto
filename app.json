{
  "expo": {
    "name": "Ready Set Disco",
    "slug": "ready-set-disco",
    "version": "1.0.0",
    "scheme": "ready-set-disco",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.robbiehey.ready-set-disco",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.robbiehey.readysetdisco",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-image",
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "b3ad7ce0-834d-4c61-81d2-f12a5db65347"
      }
    },
    "owner": "robbiehey"
  }
}
